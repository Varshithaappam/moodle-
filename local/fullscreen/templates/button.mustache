{{!
    @template local_fullscreen/button

    Renders the html that displays the fixed full screen icon on a page.

    Classes required for JS:
    * local-fullscreen-padding
    * local-fullscreen

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * fullscreen boolean
    * toggle string

    Example context (json):
    {
        "fullscreen": true,
        "toggle": "Ctrl + Alt + b"
    }
}}

<div class="local-fullscreen-padding">
    <div
            title="{{!
                }}{{#fullscreen}}{{#str}}turnoff, local_fullscreen, {{toggle}}{{/str}}{{/fullscreen}}{{!
                }}{{^fullscreen}}{{#str}}turnon, local_fullscreen, {{toggle}}{{/str}}{{/fullscreen}}{{!
            }}"
            class="local-fullscreen"
            tabindex="0"
            role="switch"
            aria-checked="{{#fullscreen}}true{{/fullscreen}}{{^fullscreen}}false{{/fullscreen}}"
            aria-label="{{#str}}togglefullscreenmode, local_fullscreen, {{toggle}}{{/str}}"
    ></div>
</div>
